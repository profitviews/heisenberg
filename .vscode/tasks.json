{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build Debug (Conan)",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "command": "source build/conanbuild.sh && cmake --build build --config Debug --parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Requires: conan install + cmake --preset conan-default once."
        },
        {
            "type": "shell",
            "label": "Build Release (Conan)",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "command": "source build/conanbuild.sh && cmake --build build --config Release --parallel",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Requires: conan install + cmake --preset conan-default once."
        }
    ]
}
